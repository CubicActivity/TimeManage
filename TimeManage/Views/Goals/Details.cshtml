@model TimeManage.Models.Goal

@{
    ViewBag.Title = "Details";
}

<h2>Details for  @Html.DisplayFor(model => model.GoalName)</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            Goal Description
        </dt>

        <dd>
            @Html.DisplayFor(model => model.GoalDescription)
        </dd>

    </dl>
</div>

<p><b>Task table</b></p>

<table class="table table-striped table-bordered table-hover">
    <thead>
        <tr>
            <th>Task Name</th>
            <th>Task Description</th>
            <th>Completed</th>
        </tr>
    </thead>
    <tbody>
        @foreach (TimeManage.Models.Tasks t in Model.Tasks)
        {
            <tr>
                <td>@t.Title</td>
                <td>@t.Description</td>
                <td class="@(t.IsComplete ? "completed" : "not-completed")">
                    @(t.IsComplete ? "✔️" : "❌")
                </td>
            </tr>
        }
    </tbody>
</table>
@Html.ActionLink("Add Tasks to your goal", "AddTasks", "Goals", new { id = Model.GoalId }, new { @Class = "btn btn-primary" })
@Html.ActionLink("Edit goal", "Edit", new { id = Model.GoalId }, new { @class = "btn btn-danger" })
@Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
