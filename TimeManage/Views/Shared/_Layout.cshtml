<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("TimeManage", "Index", "TimeTable", new { area = "" }, new { @class = "navbar-brand" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li>@Html.ActionLink("My TimeTable", "Index", "TimeTable", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("My Tasks", "Index", "Tasks", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Pomodoro", "Index", "Pomodoro", null, new { @class = "nav-link" })</li>
                </ul>
                @Html.Partial("_LoginPartial")
            </div>




        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Angel Stojmanovski (Index: 236059)</p>
        </footer>
    </div>

    <audio id="pomodoroSound" src="~/Content/sounds/ding.mp3" preload="auto"></audio>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    <script src="~/Scripts/bootbox.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            let usr = '@User.Identity.Name';
            usr = usr.slice(0, usr.lastIndexOf('@@'));

            let customTime = parseInt(localStorage.getItem(usr + "pomodoroCustomTime")) || 1500;
            let startTime = parseInt(localStorage.getItem(usr + "pomodoroStartTime"));
            let pausedTimeLeft = parseInt(localStorage.getItem(usr + "pomodoroTimeLeft"));
            if (isNaN(pausedTimeLeft)) pausedTimeLeft = customTime;

            let isPaused = localStorage.getItem(usr + "pomodoroPaused") === "true";
            let timerInterval;

            function getTimeLeft() {
                if (isPaused) return pausedTimeLeft ?? customTime;
                const elapsed = Math.floor((Date.now() - startTime) / 1000);
                const remaining = customTime - elapsed;
                if (remaining <= 0) {
                    completePomodoro();
                    return 0;
                }
                return remaining;
            }

            function updatePomodoroDisplay() {
                const minutes = Math.floor(getTimeLeft() / 60);
                const seconds = getTimeLeft() % 60;
                const displayText = `⏰Pomodoro Time remaining: ${minutes}:${seconds.toString().padStart(2,'0')}`;

                const bigTimer = document.getElementById("pomodoro-display");
                if (bigTimer) bigTimer.textContent = displayText;

                const navTimer = document.getElementById("pomodoro-timer");
                if (navTimer) navTimer.textContent = displayText;

                const startPauseBtn = document.getElementById("startPauseBtn");
                if (startPauseBtn) {
                    startPauseBtn.textContent = isPaused ? "Start timer" : "Pause timer";
                    startPauseBtn.className = isPaused ? "btn btn-success" : "btn btn-warning";
                }

                if (navTimer) navTimer.className = isPaused ? "btn btn-success" : "btn btn-warning";
            }

            function tick() {
                if (!isPaused) updatePomodoroDisplay();
            }

            function togglePomodoro() {
                if (isPaused) {
                    startTime = Date.now() - ((customTime - pausedTimeLeft) * 1000 || 0);
                    localStorage.setItem(usr + "pomodoroStartTime", startTime);
                } else {
                    pausedTimeLeft = getTimeLeft();
                    localStorage.setItem(usr + "pomodoroTimeLeft", pausedTimeLeft);
                }
                isPaused = !isPaused;
                localStorage.setItem(usr + "pomodoroPaused", isPaused);
                updatePomodoroDisplay();
            }

            function completePomodoro() {
                isPaused = true;
                localStorage.setItem(usr + "pomodoroPaused", true);
                localStorage.setItem(usr + "pomodoroTimeLeft", 0);
                updatePomodoroDisplay();

                const sound = document.getElementById("pomodoroSound");
                if (sound) {
                    sound.currentTime = 0;
                    sound.play().catch(() => { });
                }

                bootbox.alert("Pomodoro complete! Take a break.");
                resetPomodoro();
            }


            function resetPomodoro() {
                pausedTimeLeft = customTime;
                isPaused = true;
                localStorage.setItem(usr + "pomodoroTimeLeft", pausedTimeLeft);
                localStorage.setItem(usr + "pomodoroPaused", true);
                localStorage.removeItem(usr + "pomodoroStartTime");
                updatePomodoroDisplay();
            }

            function setCustomTime() {
                if (!isPaused) togglePomodoro();

                const minutes = parseInt(document.getElementById("minutesInput").value);
                const seconds = parseInt(document.getElementById("secondsInput").value);
                if (isNaN(minutes) || minutes < 0 || minutes > 59 || isNaN(seconds) || seconds < 0 || seconds > 59) {
                    bootbox.alert("Please enter valid minutes (0-59) and seconds (0-59).");
                    return;
                }

                customTime = (minutes * 60) + seconds;
                localStorage.setItem(usr + "pomodoroCustomTime", customTime);
                resetPomodoro();
            }

            const soundUnlock = () => {
                const sound = document.getElementById("pomodoroSound");
                if (sound) {
                    sound.play().then(() => sound.pause()).catch(() => {});
                }
                document.removeEventListener("click", soundUnlock);
            };
            document.addEventListener("click", soundUnlock);

            updatePomodoroDisplay();
            if (!timerInterval) timerInterval = setInterval(tick, 1000);

            window.togglePomodoro = togglePomodoro;
            window.resetPomodoro = resetPomodoro;
            window.setCustomTime = setCustomTime;
        });
    </script>



</body>
</html>
